<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="#0a0e1a">

    <!-- CONNECTION SCREEN -->
    <LinearLayout android:id="@+id/screen_connection"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="20dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Media Centre"
            android:textSize="40sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginBottom="30dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select PC to Connect"
            android:textSize="20sp"
            android:textColor="#8892b0"
            android:layout_marginBottom="20dp" />
            
        <LinearLayout android:id="@+id/ip_list_container"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:maxWidth="400dp">
            <!-- Buttons dynamically added here -->
        </LinearLayout>
        
        <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:maxWidth="400dp" android:layout_marginTop="20dp" android:weightSum="2">
            <Button android:id="@+id/btn_add_pc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ Add New PC"
                android:textColor="#00d4ff"
                android:background="#1a1f36"
                android:padding="15dp"
                android:layout_marginRight="5dp" />
            <Button android:id="@+id/btn_remove_pc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="- Remove PC"
                android:textColor="#ff3333"
                android:background="#1a1f36"
                android:padding="15dp"
                android:layout_marginLeft="5dp" />
        </LinearLayout>
            

    </LinearLayout>

    <!-- MAIN INTERFACE -->
    <LinearLayout android:id="@+id/screen_main"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical"
        android:visibility="gone">
        
        <!-- Top Bar -->
        <LinearLayout android:id="@+id/top_bar"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#111827"
            android:padding="10dp"
            android:gravity="center_vertical">
            <Button android:id="@+id/btn_disconnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disconnect"
                android:textColor="#ff5252"
                android:background="#1a1f36"
                android:paddingLeft="15dp"
                android:paddingRight="15dp" />
            <TextView android:id="@+id/tab_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Music"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />
            <Button android:id="@+id/btn_refresh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                android:textColor="#ffffff"
                android:background="#1a1f36"
                android:paddingLeft="15dp"
                android:paddingRight="15dp" />
        </LinearLayout>
        
        <!-- Content Area -->
        <FrameLayout android:id="@+id/content_area"
            android:layout_width="fill_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            
            <!-- ====== MUSIC TAB ====== -->
            <LinearLayout android:id="@+id/tab_music"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:orientation="vertical">
                
                <!-- Sub-tabs -->
                <LinearLayout android:id="@+id/music_sub_tabs"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#111827">
                    <Button android:id="@+id/btn_music_playing"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Now Playing" android:textColor="#00d4ff" android:background="#1a1f36" />
                    <Button android:id="@+id/btn_music_search"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Search" android:textColor="#8892b0" android:background="#111827" />
                    <Button android:id="@+id/btn_music_library"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Library" android:textColor="#8892b0" android:background="#111827" />
                    <Button android:id="@+id/btn_music_queue"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Queue" android:textColor="#8892b0" android:background="#111827" />
                </LinearLayout>
                
                <!-- Now Playing -->
                <ScrollView android:id="@+id/music_now_playing"
                    android:layout_width="fill_parent" android:layout_height="fill_parent">
                    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="20dp">
                        <RelativeLayout android:layout_width="200dp" android:layout_height="200dp" android:layout_marginBottom="20dp">
                            <ImageView android:id="@+id/np_artwork"
                                android:layout_width="fill_parent" android:layout_height="fill_parent" />
                            <ProgressBar android:id="@+id/np_art_progress"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_centerInParent="true" android:visibility="gone" />
                            <LinearLayout android:id="@+id/np_art_error_layout"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_centerInParent="true" android:orientation="vertical"
                                android:gravity="center" android:visibility="gone">
                                <TextView android:id="@+id/np_art_error_text"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Failed to download" android:textColor="#ffffff" android:textSize="12sp"
                                    android:gravity="center" android:layout_marginBottom="10dp" />
                                <Button android:id="@+id/np_art_retry_btn"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Retry" android:textSize="12sp" android:padding="5dp"
                                    android:textColor="#ffffff" android:background="#44ffffff" />
                            </LinearLayout>
                        </RelativeLayout>
                        <TextView android:id="@+id/np_title"
                            android:layout_width="fill_parent" android:layout_height="wrap_content"
                            android:text="Not Playing" android:textColor="#ffffff" android:textSize="24sp"
                            android:textStyle="bold" android:gravity="center" android:layout_marginBottom="5dp" />
                        <TextView android:id="@+id/np_artist"
                            android:layout_width="fill_parent" android:layout_height="wrap_content"
                            android:text="" android:textColor="#8892b0" android:textSize="18sp"
                            android:gravity="center" android:layout_marginBottom="5dp" />
                        <TextView android:id="@+id/np_album"
                            android:layout_width="fill_parent" android:layout_height="wrap_content"
                            android:text="" android:textColor="#8892b0" android:textSize="16sp"
                            android:gravity="center" android:layout_marginBottom="10dp" />
                            
                        <!-- Progress Bar -->
                        <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_marginBottom="15dp" android:paddingLeft="10dp" android:paddingRight="10dp">
                            <Button android:id="@+id/btn_seek_back" android:layout_width="60dp" android:layout_height="40dp"
                                android:text="-15s" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginRight="10dp"/>
                            <TextView android:id="@+id/np_time_current" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="00:00" android:textColor="#8892b0" android:textSize="12sp" android:layout_marginRight="10dp"/>
                            <SeekBar android:id="@+id/np_progress" android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:max="100"/>
                            <TextView android:id="@+id/np_time_total" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="00:00" android:textColor="#8892b0" android:textSize="12sp" android:layout_marginLeft="10dp" android:layout_marginRight="10dp"/>
                            <Button android:id="@+id/btn_seek_fwd" android:layout_width="60dp" android:layout_height="40dp"
                                android:text="+15s" android:textColor="#ffffff" android:background="#1a1f36"/>
                        </LinearLayout>
                            
                        <!-- Playback Controls -->
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp" android:gravity="center">
                            <Button android:id="@+id/btn_prev" android:layout_width="60dp" android:layout_height="wrap_content"
                                android:text="&lt;&lt;" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginRight="10dp"/>
                            <Button android:id="@+id/btn_play_pause" android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Play/Pause" android:textColor="#ffffff" android:background="#00d4ff" android:layout_marginRight="10dp"/>
                            <Button android:id="@+id/btn_next" android:layout_width="60dp" android:layout_height="wrap_content"
                                android:text="&gt;&gt;" android:textColor="#ffffff" android:background="#1a1f36" />
                        </LinearLayout>

                        <!-- Extra Actions -->
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="20dp" android:gravity="center">
                            <Button android:id="@+id/btn_np_like" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Like" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginRight="10dp"/>
                            <Button android:id="@+id/btn_np_playlist" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Add to Playlist" android:textColor="#ffffff" android:background="#1a1f36" />
                        </LinearLayout>
                        
                        <!-- Volume -->
                        <LinearLayout android:layout_width="350dp" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">
                            <Button android:id="@+id/btn_vol_down" android:layout_width="50dp" android:layout_height="wrap_content"
                                android:text="-5%" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginRight="5dp"/>
                            <TextView android:id="@+id/vol_label" android:layout_width="40dp" android:layout_height="wrap_content"
                                android:text="50%" android:textColor="#ffffff" android:gravity="center" />
                            <SeekBar android:id="@+id/seekBar_volume" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:max="100" android:progress="50" android:padding="10dp" />
                            <Button android:id="@+id/btn_vol_up" android:layout_width="50dp" android:layout_height="wrap_content"
                                android:text="+5%" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginLeft="5dp"/>
                        </LinearLayout>
                        
                        <!-- Shuffle/Repeat -->
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <Button android:id="@+id/btn_shuffle" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Shuffle" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginRight="10dp"/>
                            <Button android:id="@+id/btn_repeat" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Repeat" android:textColor="#ffffff" android:background="#1a1f36" />
                        </LinearLayout>
                    </LinearLayout>
                </ScrollView>
                
                <!-- Search -->
                <LinearLayout android:id="@+id/music_search"
                    android:layout_width="fill_parent" android:layout_height="fill_parent"
                    android:orientation="vertical" android:visibility="gone" android:padding="10dp">
                    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <EditText android:id="@+id/search_input" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:hint="Search Spotify..." android:textColor="#000000" android:textColorHint="#8892b0" android:singleLine="true" android:background="#ffffff" android:padding="10dp" />
                        <EditText android:id="@+id/search_limit" android:layout_width="50dp" android:layout_height="wrap_content" 
                            android:inputType="number" android:text="10" android:textColor="#000000" android:background="#ffffff" android:padding="10dp" android:layout_marginLeft="5dp" />
                        <Spinner android:id="@+id/search_type_spinner" android:layout_width="100dp" android:layout_height="wrap_content" android:layout_marginLeft="5dp" />
                        <Button android:id="@+id/btn_search" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Search" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginLeft="5dp" />
                    </LinearLayout>
                    <ScrollView android:layout_width="fill_parent" android:layout_height="fill_parent" android:layout_marginTop="10dp">
                        <LinearLayout android:id="@+id/search_results" android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                    </ScrollView>
                </LinearLayout>
                
                <!-- Library -->
                <ScrollView android:id="@+id/music_library"
                    android:layout_width="fill_parent" android:layout_height="fill_parent"
                    android:visibility="gone" android:padding="10dp">
                    <LinearLayout android:id="@+id/library_content" android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </ScrollView>
                
                <!-- Queue -->
                <ScrollView android:id="@+id/music_queue"
                    android:layout_width="fill_parent" android:layout_height="fill_parent"
                    android:visibility="gone" android:padding="10dp">
                    <LinearLayout android:id="@+id/queue_content" android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>
            

            <!-- ====== SETTINGS TAB ====== -->
            <ScrollView android:id="@+id/tab_settings"
                android:layout_width="fill_parent" android:layout_height="fill_parent"
                android:visibility="gone">
                <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="System Settings" android:textColor="#ffffff" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="10dp"/>
                        
                    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Show Album Art" android:textColor="#ffffff" android:textSize="18sp"/>
                        <ToggleButton android:id="@+id/toggle_album_art" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    
                    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                            android:text="Theme" android:textColor="#ffffff" android:textSize="18sp"/>
                        <Button android:id="@+id/btn_theme" android:layout_width="100dp" android:layout_height="wrap_content" android:text="Dark" />
                    </LinearLayout>
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PC Usage" android:textColor="#ffffff" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="20dp" android:layout_marginBottom="10dp"/>
                        
                    <TextView android:id="@+id/cpu_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CPU: 0%" android:textColor="#8892b0" />
                    <ProgressBar android:id="@+id/cpu_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:max="100"/>
                    
                    <TextView android:id="@+id/ram_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAM: 0%" android:textColor="#8892b0" />
                    <ProgressBar android:id="@+id/ram_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:max="100"/>
                    
                    <TextView android:id="@+id/disk_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Disk RW: 0%" android:textColor="#8892b0" />
                    <ProgressBar android:id="@+id/disk_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:max="100"/>
                    
                    <TextView android:id="@+id/gpu_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GPU: 0%" android:textColor="#8892b0" />
                    <ProgressBar android:id="@+id/gpu_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="fill_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:max="100"/>
                    
                    <TextView android:id="@+id/last_updated_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Last Updated: --" android:textColor="#8892b0" android:layout_marginTop="5dp" />
                    
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Audio" android:textColor="#ffffff" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="20dp" android:layout_marginBottom="10dp"/>
                    
                    <TextView android:id="@+id/audio_channel_text" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Channels: --" android:textColor="#8892b0" android:layout_marginBottom="10dp" />
                    
                    <LinearLayout android:layout_width="fill_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Speaker Fill (5.1)" android:textColor="#ffffff" android:textSize="18sp"/>
                        <ToggleButton android:id="@+id/toggle_speaker_fill" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    
                    <Button android:id="@+id/btn_speaker_config" android:layout_width="fill_parent" android:layout_height="wrap_content"
                        android:text="Open Speaker Config on PC" android:textColor="#ffffff" android:background="#1a1f36" android:layout_marginBottom="10dp" />
                </LinearLayout>
            </ScrollView>
            
            <!-- ====== POWER TAB ====== -->
            <LinearLayout android:id="@+id/tab_power"
                android:layout_width="fill_parent" android:layout_height="fill_parent"
                android:orientation="vertical" android:visibility="gone" android:gravity="center" android:padding="20dp">
                
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Power Options" android:textColor="#ffffff" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="40dp"/>
                    
                <Button android:id="@+id/btn_shutdown" android:layout_width="250dp" android:layout_height="70dp"
                    android:text="Shutdown PC" android:textColor="#ffffff" android:background="#ff5252" android:textSize="18sp" android:layout_marginBottom="20dp"/>
                    
                <Button android:id="@+id/btn_restart" android:layout_width="250dp" android:layout_height="70dp"
                    android:text="Restart PC" android:textColor="#ffffff" android:background="#ffa726" android:textSize="18sp" android:layout_marginBottom="20dp"/>
                    
                <Button android:id="@+id/btn_close_app" android:layout_width="250dp" android:layout_height="70dp"
                    android:text="Close PC App" android:textColor="#ffffff" android:background="#1a1f36" android:textSize="18sp"/>
            </LinearLayout>
            
        </FrameLayout>
        
        <!-- Bottom Tab Bar -->
        <LinearLayout android:id="@+id/tab_bar"
            android:layout_width="fill_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:background="#111827">
            <Button android:id="@+id/tab_btn_music" android:layout_width="0dp" android:layout_height="fill_parent" android:layout_weight="1"
                android:text="MUSIC" android:textColor="#00d4ff" android:background="#1a1f36" />

            <Button android:id="@+id/tab_btn_settings" android:layout_width="0dp" android:layout_height="fill_parent" android:layout_weight="1"
                android:text="SETTINGS" android:textColor="#8892b0" android:background="#111827" />
            <Button android:id="@+id/tab_btn_power" android:layout_width="0dp" android:layout_height="fill_parent" android:layout_weight="1"
                android:text="POWER" android:textColor="#8892b0" android:background="#111827" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- Loading Overlay -->
    <LinearLayout android:id="@+id/loading_overlay"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">
        <ProgressBar android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="20dp" />
        <TextView android:id="@+id/loading_text"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Waiting for PC to respond..."
            android:textColor="#ffffff"
            android:textSize="20sp" />
    </LinearLayout>
    
    <!-- Toast Message -->
    <TextView android:id="@+id/status_toast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="20dp"
        android:background="#4CAF50"
        android:textColor="#ffffff"
        android:paddingLeft="20dp" android:paddingRight="20dp" android:paddingTop="10dp" android:paddingBottom="10dp"
        android:textSize="16sp"
        android:visibility="gone" />

</FrameLayout>
